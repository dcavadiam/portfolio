---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Portfolio">
  <main class="flex flex-col items-center min-h-screen py-2">
    <section>
      <div class="flex flex-col items-center justify-center">
        <img
          src="https://avatars.githubusercontent.com/u/89433295?v=4"
          alt="Diego Cavadia"
          class="w-32 h-32 rounded-full my-4 border-4 border-white"
        />
      </div>
      <div>
        <h1>Hi 👋, I'm <span class="text-gradient">Diego Cavadia</span></h1>
      </div>
      <p class="text-center">
        I'm a Software Engineer specialized in Frontend Development. I love
        create beautiful and functional user interfaces. 
      </p>
    </section>
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding: 1rem;
    width: 800px;
    max-width: calc(100% - 2rem);
    color: white;
    font-size: 20px;
    line-height: 1.6;
  }
  h1 {
    font-size: 4rem;
    font-weight: 700;
    line-height: 1;
    text-align: center;
    margin-bottom: 0.5em;
  }
  .text-gradient {
    background-image: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 400%;
    background-position: 0%;
  }
</style>
